<Window
    x:Class="DesktopPet.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="DesktopPet Control Center">

    <Grid RowDefinitions="Auto,*" Padding="16" RowSpacing="16">
        <CommandBar DefaultLabelPosition="Right">
            <AppBarButton x:Name="ShowPetButton" Icon="View" Label="显示宠物" Click="OnShowPetClicked"/>
            <AppBarButton x:Name="HidePetButton" Icon="HideBcc" Label="隐藏宠物" Click="OnHidePetClicked"/>
            <AppBarButton x:Name="WaveButton" Icon="Emoji2" Label="挥手" Click="OnWaveClicked"/>
        </CommandBar>

        <Grid Grid.Row="1" ColumnDefinitions="2*,*" ColumnSpacing="24">
            <StackPanel Spacing="12">
                <TextBlock Text="桌面宠物控制中心" FontSize="26" FontWeight="SemiBold"/>
                <TextBlock x:Name="StatusText" Text="状态：启动中" TextWrapping="Wrap"/>

                <Border Padding="12" CornerRadius="8" BorderThickness="1" BorderBrush="#33000000">
                    <StackPanel Spacing="10">
                        <TextBlock Text="运行控制" FontWeight="SemiBold"/>
                        <CheckBox x:Name="AlwaysTopCheck" Content="宠物窗口置顶" IsChecked="True" Click="OnAlwaysTopClicked"/>
                        <CheckBox x:Name="MuteCheck" Content="静音"/>
                        <Button Content="写入一条测试记忆" Click="OnWriteMemoryClicked"/>
                    </StackPanel>
                </Border>

                <Border Padding="12" CornerRadius="8" BorderThickness="1" BorderBrush="#33000000">
                    <StackPanel Spacing="8">
                        <TextBlock Text="对话测试" FontWeight="SemiBold"/>
                        <TextBox x:Name="SpeakTextBox" PlaceholderText="输入一句要让宠物说的话"/>
                        <Button Content="说话 / 触发动作" Click="OnSpeakClicked"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="12">
                    <TextBlock Text="外观" FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock Text="缩放"/>
                    <TextBlock x:Name="ScaleValueText" Text="1.00x"/>
                    <Slider x:Name="ScaleSlider" Minimum="0.1" Maximum="2.0" StepFrequency="0.01" Value="1.0" ValueChanged="OnScaleChanged"/>
                    <TextBlock Text="模型"/>
                    <ComboBox x:Name="ModelComboBox" SelectionChanged="OnModelSelectionChanged">
                        <ComboBoxItem Content="默认模型 1.fbx"/>
                        <ComboBoxItem Content="EL_F_EY_N_13500"/>
                    </ComboBox>
                    <Button Content="手动选择 FBX 模型" Click="OnBrowseModelClicked"/>
                    <TextBlock x:Name="ModelPathText" Text="当前模型：1.fbx" TextWrapping="Wrap"/>
                    <TextBlock Text="水平旋转"/>
                    <Slider x:Name="ModelYawSlider" Minimum="-180" Maximum="180" StepFrequency="1" Value="0" ValueChanged="OnModelRotationChanged"/>
                    <TextBlock x:Name="ModelYawText" Text="0°"/>
                    <TextBlock Text="垂直旋转"/>
                    <Slider x:Name="ModelPitchSlider" Minimum="-180" Maximum="180" StepFrequency="1" Value="0" ValueChanged="OnModelRotationChanged"/>
                    <TextBlock x:Name="ModelPitchText" Text="0°"/>
                    <TextBlock Text="平面旋转"/>
                    <Slider x:Name="ModelRollSlider" Minimum="-180" Maximum="180" StepFrequency="1" Value="0" ValueChanged="OnModelRotationChanged"/>
                    <TextBlock x:Name="ModelRollText" Text="0°"/>
                    <Button Content="重置模型旋转" Click="OnResetModelRotationClicked"/>
                    <TextBlock Text="材质" FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock Text="亮度"/>
                    <Slider x:Name="MaterialBrightnessSlider" Minimum="0" Maximum="3" StepFrequency="0.01" Value="1" ValueChanged="OnMaterialChanged"/>
                    <TextBlock x:Name="MaterialBrightnessText" Text="1.00"/>
                    <TextBlock Text="对比度"/>
                    <Slider x:Name="MaterialContrastSlider" Minimum="0" Maximum="3" StepFrequency="0.01" Value="1" ValueChanged="OnMaterialChanged"/>
                    <TextBlock x:Name="MaterialContrastText" Text="1.00"/>
                    <TextBlock Text="饱和度"/>
                    <Slider x:Name="MaterialSaturationSlider" Minimum="0" Maximum="3" StepFrequency="0.01" Value="1" ValueChanged="OnMaterialChanged"/>
                    <TextBlock x:Name="MaterialSaturationText" Text="1.00"/>
                    <TextBlock Text="环境光"/>
                    <Slider x:Name="MaterialAmbientSlider" Minimum="0" Maximum="2" StepFrequency="0.01" Value="0.22" ValueChanged="OnMaterialChanged"/>
                    <TextBlock x:Name="MaterialAmbientText" Text="0.22"/>
                    <TextBlock Text="直射光"/>
                    <Slider x:Name="MaterialDirectLightSlider" Minimum="0" Maximum="3" StepFrequency="0.01" Value="0.78" ValueChanged="OnMaterialChanged"/>
                    <TextBlock x:Name="MaterialDirectLightText" Text="0.78"/>
                    <TextBlock Text="高光"/>
                    <Slider x:Name="MaterialSpecularSlider" Minimum="0" Maximum="3" StepFrequency="0.01" Value="0" ValueChanged="OnMaterialChanged"/>
                    <TextBlock x:Name="MaterialSpecularText" Text="0.00"/>
                    <TextBlock Text="粗糙度"/>
                    <Slider x:Name="MaterialRoughnessSlider" Minimum="0" Maximum="1" StepFrequency="0.01" Value="0.45" ValueChanged="OnMaterialChanged"/>
                    <TextBlock x:Name="MaterialRoughnessText" Text="0.45"/>
                    <Button Content="重置材质参数" Click="OnResetMaterialClicked"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
